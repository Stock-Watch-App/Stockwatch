# Supabase Configuration for Stockwatch Migration
# Copy these variables to your .env file and update with your Supabase project details

# Application
APP_NAME=Stockwatch
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-domain.com

# Database (Supabase PostgreSQL)
DB_CONNECTION=pgsql
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_KEY=your-service-role-secret-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Database Connection (Direct PostgreSQL connection)
SUPABASE_DB_HOST=db.your-project-ref.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_DATABASE=postgres
SUPABASE_DB_USERNAME=postgres
SUPABASE_DB_PASSWORD=your-database-password

# For local development, you can still use these fallbacks
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=stockwatch
DB_USERNAME=postgres
DB_PASSWORD=

# Authentication providers (enable as needed)
SUPABASE_GOOGLE_ENABLED=true
SUPABASE_FACEBOOK_ENABLED=true
SUPABASE_TWITTER_ENABLED=true
SUPABASE_DISCORD_ENABLED=true
SUPABASE_TWITCH_ENABLED=true
SUPABASE_REDDIT_ENABLED=true

# Cache & Session (can use database or Redis)
CACHE_DRIVER=database
SESSION_DRIVER=database
QUEUE_CONNECTION=database

# Mail (optional - for notifications)
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@stockwatch.app
MAIL_FROM_NAME="${APP_NAME}"

# Logging
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# File Storage (can use Supabase Storage or S3)
FILESYSTEM_DRIVER=public

# Other settings
BROADCAST_DRIVER=log
MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Remove these Laravel-specific keys that are no longer needed:
# - FORGE_ variables
# - NOVA_ variables
# - Complex queue configurations